<Window x:Class="MissMinuteJarvis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Miss Minute Jarvis" Height="600" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" WindowStartupLocation="Manual" ShowInTaskbar="False">
    
    <Grid x:Name="MainGrid" Background="#01000000"> <!-- Background quasi invisibile per hit-test -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Open Dashboard" Click="OpenDashboard_Click"/>
                <Separator/>
                <MenuItem Header="Restart Jarvis" Click="Restart_Click"/>
                <MenuItem Header="Exit All (Total)" Click="ExitAll_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- Pulsante di chiusura di emergenza (piccolo in alto a dx) -->
        <Button Content="X" VerticalAlignment="Top" HorizontalAlignment="Right" Width="20" Height="20" 
                Background="#20FF0000" Foreground="White" BorderThickness="0" Click="ExitAll_Click" Opacity="0.2"/>

        <Canvas x:Name="HoloCanvas" Width="600" Height="600">
            <Ellipse x:Name="Ring1" Width="320" Height="320" Canvas.Left="140" Canvas.Top="140" Stroke="#60FF8C00" StrokeThickness="1" StrokeDashArray="2 10"/>
            <Ellipse x:Name="Ring2" Width="360" Height="360" Canvas.Left="120" Canvas.Top="120" Stroke="#40FF4500" StrokeThickness="2" StrokeDashArray="20 5"/>
        </Canvas>

        <Grid x:Name="CharacterRoot">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="BodyScale" CenterX="300" CenterY="300"/>
                    <TranslateTransform x:Name="BodyTranslate"/>
                    <SkewTransform x:Name="BodySkew" CenterX="300" CenterY="300"/>
                </TransformGroup>
            </Grid.RenderTransform>

            <Ellipse x:Name="CoreGlow" Width="220" Height="220" Fill="#FF8C00" Opacity="0.4" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Ellipse.Effect><BlurEffect Radius="100"/></Ellipse.Effect>
            </Ellipse>

            <Canvas x:Name="MainCanvas" Width="600" Height="600">
                <Path x:Name="LeftArm" Stroke="#211007" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path x:Name="RightArm" Stroke="#211007" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path x:Name="LeftLeg" Stroke="#211007" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                <Path x:Name="RightLeg" Stroke="#211007" StrokeThickness="9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>

                <Ellipse x:Name="LeftGlove" Width="32" Height="32" Fill="White" Stroke="#211007" StrokeThickness="2.5"/>
                <Ellipse x:Name="RightGlove" Width="32" Height="32" Fill="White" Stroke="#211007" StrokeThickness="2.5"/>
                <Ellipse x:Name="LeftShoe" Width="50" Height="28" Fill="#211007"/>
                <Ellipse x:Name="RightShoe" Width="50" Height="28" Fill="#211007"/>

                <Ellipse Width="160" Height="160" Canvas.Left="220" Canvas.Top="220" Fill="#FFDAB9" Stroke="#211007" StrokeThickness="4.5"/>
                <Ellipse x:Name="InnerFace" Width="146" Height="146" Canvas.Left="227" Canvas.Top="227" Fill="#FF4500"/>
                <Canvas x:Name="TicksCanvas" Width="160" Height="160" Canvas.Left="220" Canvas.Top="220"/>

                <Ellipse Width="36" Height="56" Canvas.Left="250" Canvas.Top="255" Fill="White" Stroke="#211007" StrokeThickness="2.5"/>
                <Ellipse Width="36" Height="56" Canvas.Left="314" Canvas.Top="255" Fill="White" Stroke="#211007" StrokeThickness="2.5"/>
                <Ellipse x:Name="LeftPupil" Width="16" Height="24" Canvas.Left="260" Canvas.Top="270" Fill="Black"/>
                <Ellipse x:Name="RightPupil" Width="16" Height="24" Canvas.Left="324" Canvas.Top="270" Fill="Black"/>

                <Path x:Name="MouthPath" Stroke="#211007" StrokeThickness="5" StrokeEndLineCap="Round"/>
            </Canvas>
        </Grid>

        <Border x:Name="StatusBubble" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,50,0,0" 
                Background="#E0000000" BorderBrush="#FF8C00" BorderThickness="2" CornerRadius="15" Padding="25,12" Opacity="0">
            <StackPanel>
                <TextBlock x:Name="StatusText" Foreground="#FFD700" FontWeight="Bold" FontSize="15" TextAlignment="Center"/>
                <TextBlock x:Name="DeadlineText" Foreground="#FF4500" FontWeight="Bold" FontSize="12" Margin="0,5,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>